{{#> layout
    headerGradient="linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%)"
    headerIcon="🔗"
    translations=translations
    app=app
}}
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
    <tr>
        <td style="padding-bottom:20px;color:#4b5563;line-height:1.6;">{{{translations.message}}}</td>
    </tr>
    <tr>
        <td style="padding:16px 0;text-align:center;">
            <a href="{{magicLink}}" style="display:inline-block;padding:14px 32px;background:linear-gradient(135deg,#4f46e5,#7c3aed);color:#ffffff;text-decoration:none;border-radius:8px;font-weight:600;font-size:16px;">{{translations.button}}</a>
        </td>
    </tr>
    <tr>
        <td style="padding-bottom:8px;font-size:14px;color:#6b7280;">{{translations.expiry}}</td>
    </tr>
    <tr>
        <td style="font-size:13px;color:#9ca3af;font-style:italic;">{{translations.security}}</td>
    </tr>
</table>
{{/layout}}
