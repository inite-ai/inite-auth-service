generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String    @id @default(uuid()) @db.Uuid
  did                      String    @unique
  email                    String?   @unique
  emailVerified            Boolean   @default(false) @map("emailVerified")
  name                     String?
  avatarUrl                String?   @map("avatarUrl")
  bio                      String?
  location                 String?
  profession               String?
  passwordHash             String?   @map("passwordHash")
  twoFactorSecret          String?   @map("twoFactorSecret")
  twoFactorEnabled         Boolean   @default(false) @map("twoFactorEnabled")
  emailVerificationToken   String?   @map("emailVerificationToken")
  emailVerificationExpires DateTime? @map("emailVerificationExpires")
  passwordResetToken       String?   @map("passwordResetToken")
  passwordResetExpires     DateTime? @map("passwordResetExpires")
  /// Number of consecutive failed password-login attempts. Reset to 0
  /// on successful login. Drives exponential backoff in
  /// AuthService.loginWithPassword — see lockoutUntil.
  failedLoginCount         Int       @default(0) @map("failedLoginCount")
  /// Timestamp until which password-login is rejected for this user.
  /// Cleared on successful login. Set after failedLoginCount crosses
  /// 5 with progressively longer windows (1m → 5m → 15m → 1h → 24h).
  lockoutUntil             DateTime? @map("lockoutUntil")
  metadata                 Json?
  createdAt                DateTime  @default(now()) @map("createdAt")
  updatedAt                DateTime  @updatedAt @map("updatedAt")

  passkeys           Passkey[]
  wallets            Wallet[]
  refreshTokens      RefreshToken[]
  authorizationCodes AuthorizationCode[]
  magicLinks         MagicLink[]
  knownDevices       UserKnownDevice[]
  oauthIdentities    OAuthIdentity[]

  @@map("users")
}

/// External IdP federation link (social login). One row per
/// (provider, providerSubject) pair, pointing at a local user. JIT-creates
/// or links a user on first federated login; subsequent logins resolve the
/// same user via the unique (provider, providerSubject) index. See
/// src/auth/federation. provider is a stable slug: "google", "github", or
/// "oidc" for the generic connector.
model OAuthIdentity {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("userId") @db.Uuid
  provider        String
  /// The IdP's stable subject identifier for this user (OIDC `sub`,
  /// GitHub numeric id, etc.). Unique per provider.
  providerSubject String   @map("providerSubject")
  email           String?
  emailVerified   Boolean  @default(false) @map("emailVerified")
  displayName     String?  @map("displayName")
  avatarUrl       String?  @map("avatarUrl")
  /// Non-sensitive claims snapshot from the last login (name, picture,
  /// locale, …). Never stores provider access/refresh tokens.
  profile         Json?
  createdAt       DateTime @default(now()) @map("createdAt")
  updatedAt       DateTime @updatedAt @map("updatedAt")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
  @@map("oauth_identities")
}

model Passkey {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("userId") @db.Uuid
  credentialId String   @unique @map("credentialId")
  publicKey    String   @map("publicKey") @db.Text
  counter      Int      @default(0)
  deviceType   String?  @map("deviceType")
  deviceName   String?  @map("deviceName")
  transports   Json?
  createdAt    DateTime @default(now()) @map("createdAt")
  lastUsedAt   DateTime @updatedAt @map("lastUsedAt")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}

model Wallet {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("userId") @db.Uuid
  address   String   @unique
  chain     String
  signature String   @db.Text
  message   String?  @db.Text
  linkedAt  DateTime @default(now()) @map("linkedAt")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("wallets")
}

model OAuthClient {
  id                String   @id @default(uuid()) @db.Uuid
  clientId          String   @unique @map("clientId")
  clientSecretHash  String   @map("clientSecretHash")
  /// Previous client_secret hash retained during the grace window
  /// after rotation. validateClient accepts both current and previous
  /// hashes until `previousSecretExpiresAt`, giving deployed callers
  /// time to roll forward without an outage.
  previousSecretHash       String?   @map("previousSecretHash")
  previousSecretExpiresAt  DateTime? @map("previousSecretExpiresAt")
  name              String
  redirectUris      String[] @map("redirectUris")
  allowedScopes     String[] @default([]) @map("allowedScopes")
  allowedGrants     String[] @default(["authorization_code", "refresh_token"]) @map("allowedGrants")
  /// Tenant identifier embedded as `sub` in JWTs issued via the
  /// client_credentials grant. Null for user-flow clients (those use
  /// the user's DID as sub). Set for machine clients calling brain
  /// or other horizontal services that key data by company.
  companyId         String?  @map("companyId")
  /// Permitted audiences for M2M JWTs. Without this allow-list a
  /// stolen client_credentials pair could mint tokens for any
  /// downstream service. Empty array = "no constraint" (issuer falls
  /// back to clientId as audience). Set explicitly when provisioning
  /// machine clients via the admin UI.
  allowedAudiences  String[] @default([]) @map("allowedAudiences")
  /// Marks the client as a public client (RFC 6749 §2.1) — no
  /// client_secret. Token-endpoint authentication relies on PKCE
  /// (authorization_code) or the device_code itself (device flow)
  /// instead of a shared secret. Set true for CLIs, native apps,
  /// and other zero-trust environments.
  isPublic          Boolean  @default(false) @map("isPublic")
  /// Confidential-client authentication method (RFC 7591
  /// token_endpoint_auth_method). "client_secret_post" (default) uses the
  /// shared secret; "private_key_jwt" (RFC 7523) authenticates with a signed
  /// JWT assertion verified against the client's registered keys below;
  /// "none" is a public client.
  tokenEndpointAuthMethod String @default("client_secret_post") @map("tokenEndpointAuthMethod")
  /// RFC 7591 client key material used to verify private_key_jwt client
  /// assertions AND signed request objects (JAR, RFC 9101). Exactly one of
  /// jwks (inline JWK Set) / jwksUri (remote) is set for a private_key_jwt
  /// client.
  jwks              Json?    @map("jwks")
  jwksUri           String?  @map("jwksUri")
  /// Optional pin for the alg a JAR request object must be signed with.
  requestObjectSigningAlg String? @map("requestObjectSigningAlg")
  active            Boolean  @default(true)
  logoUrl           String?  @map("logoUrl")
  privacyPolicyUrl  String?  @map("privacyPolicyUrl")
  termsOfServiceUrl String?  @map("termsOfServiceUrl")
  /// OIDC Back-Channel Logout (https://openid.net/specs/openid-connect-backchannel-1_0.html).
  /// When set, /oauth/logout POSTs a signed logout_token to this URL
  /// so the RP can invalidate its local session before the user's next
  /// request. Required for SSO sign-out parity across multiple RPs.
  backchannelLogoutUri String? @map("backchannelLogoutUri")
  createdAt         DateTime @default(now()) @map("createdAt")
  updatedAt         DateTime @updatedAt @map("updatedAt")

  refreshTokens      RefreshToken[]
  authorizationCodes AuthorizationCode[]

  @@map("oauth_clients")
}

/// Single-use guard for private_key_jwt client assertions (RFC 7523). Each
/// accepted assertion's (clientId, jti) is recorded so a replay of the same
/// assertion within its lifetime is rejected. Rows are reaped after expiry.
model ClientAssertionJti {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("clientId")
  jti       String   @map("jti")
  expiresAt DateTime @map("expiresAt")
  createdAt DateTime @default(now()) @map("createdAt")

  @@unique([clientId, jti], map: "client_assertion_jti_clientId_jti_key")
  @@index([expiresAt], map: "client_assertion_jti_expiresAt_idx")
  @@map("client_assertion_jti")
}

/// Durable audit trail for OAuth + client lifecycle events.
/// Replaces console-only logging so security forensics and
/// compliance reviews don't depend on container log retention.
model OAuthAuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  ts            DateTime @default(now())
  event         String
  clientId      String?
  /// Tenant scope, denormalised from the OAuthClient at write-time.
  /// Lets scoped admin reads filter without a join (and ensures the
  /// filter still works after a client is deleted/renamed).
  companyId     String?
  sub           String?
  scopes        String[] @default([])
  audience      String?
  ip            String?
  userAgent     String?
  success       Boolean
  errorMessage  String?
  metadata      Json?

  @@index([clientId, ts(sort: Desc)], map: "oauth_audit_log_clientId_ts_idx")
  @@index([event, ts(sort: Desc)], map: "oauth_audit_log_event_ts_idx")
  @@index([companyId, ts(sort: Desc)], map: "oauth_audit_log_companyId_ts_idx")
  @@map("oauth_audit_log")
}

model AuthorizationCode {
  id                  String   @id @default(uuid()) @db.Uuid
  code                String   @unique
  userId              String   @map("userId") @db.Uuid
  clientId            String   @map("clientId")
  /// Tenant scope, denormalised from OAuthClient at create-time. Null
  /// for user-flow clients (no tenant), set for company-keyed M2M.
  companyId           String?  @map("companyId")
  redirectUri         String   @map("redirectUri")
  scope               String?
  /// OIDC nonce parameter (core §3.1.2.1). Persisted at /authorize and
  /// embedded into the id_token at /token. Required to bind a given
  /// id_token to the original authorization request — without it, an
  /// attacker who intercepts a code can replay a stolen id_token.
  nonce               String?
  /// Requested ACR values (OIDC core §3.1.2.1). Whitespace-separated
  /// list passed verbatim from /authorize. The IdP echoes the matched
  /// value back via id_token.acr — RPs use it to enforce step-up auth.
  acrValues           String?  @map("acrValues")
  /// Authentication Methods References — list of methods (pwd, fido,
  /// otp, mfa, magic-link) that built the session, captured at the
  /// time the auth code was issued. Embedded into id_token.amr.
  amr                 String[] @default([]) @map("amr")
  codeChallenge       String?  @map("codeChallenge")
  codeChallengeMethod String?  @map("codeChallengeMethod")
  /// RFC 8707 Resource Indicator. The protected resource the RP requested
  /// this code be exchanged for; at /token it binds the issued access
  /// token's `aud` (validated against the client's allowedAudiences).
  resource            String?
  expiresAt           DateTime @map("expiresAt")
  used                Boolean  @default(false)
  createdAt           DateTime @default(now()) @map("createdAt")

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([userId])
  @@map("authorization_codes")
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  // Deterministic HMAC-SHA256(REFRESH_TOKEN_HMAC_SECRET, rawToken) used for
  // O(1) indexed lookup AND verification (knowing the lookup proves the
  // token was minted with this server's HMAC secret). Replaces the previous
  // bcrypt-based scan-all-rows-and-compare approach.
  tokenLookup String?   @unique @map("tokenLookup")
  // Legacy bcrypt-hashed value, only present on rows minted before the
  // refresh-token rewrite. New rows leave this null. Cleanup cron will
  // delete legacy rows once they expire (max 7d).
  tokenHash   String?   @map("tokenHash")
  userId      String    @map("userId") @db.Uuid
  clientId    String    @map("clientId")
  /// Tenant scope, denormalised from OAuthClient at issue-time.
  companyId   String?   @map("companyId")
  scope       String?
  /// OIDC nonce carried forward across refresh-token rotation, so
  /// id_tokens minted via refresh still embed the same nonce as the
  /// original (OIDC core §12.1).
  nonce       String?
  /// Carry AMR forward across rotation so refresh-issued id_tokens
  /// keep the original authentication context.
  amr         String[] @default([]) @map("amr")
  expiresAt   DateTime  @map("expiresAt")
  rotatedFrom String?   @map("rotatedFrom") @db.Uuid
  revoked     Boolean   @default(false)
  revokedAt   DateTime? @map("revokedAt")
  createdAt   DateTime  @default(now()) @map("createdAt")

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([userId])
  @@index([userId, clientId, revoked])
  @@index([companyId, revoked], map: "refresh_tokens_companyId_revoked_idx")
  @@map("refresh_tokens")
}

model MagicLink {
  id          String    @id @default(uuid()) @db.Uuid
  token       String    @unique
  email       String
  userId      String?   @map("userId") @db.Uuid
  purpose     String
  expiresAt   DateTime  @map("expiresAt")
  used        Boolean   @default(false)
  usedAt      DateTime? @map("usedAt")
  oauthParams Json?     @map("oauthParams")
  createdAt   DateTime  @default(now()) @map("createdAt")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("magic_links")
}

/// OAuth 2.0 Device Authorization Grant (RFC 8628).
/// Persists state for the device flow: a TV/CLI/IoT client requests
/// a device_code + user_code; the user authorises via a separate
/// browser session; the client polls /token with device_code until
/// status transitions to APPROVED.
model DeviceAuthorization {
  id           String   @id @default(uuid()) @db.Uuid
  /// Long random opaque code returned to the device; client polls
  /// /token with this. Hashed at rest via SHA-256 so a DB read can't
  /// approve random codes.
  deviceCodeHash String @unique @map("deviceCodeHash")
  /// Short user-facing code (8 chars, format XXXX-XXXX). Stored
  /// plain because the user needs to type it.
  userCode     String   @unique @map("userCode")
  clientId     String   @map("clientId")
  scope        String?
  /// Set when the user approves; null while pending.
  userId       String?  @map("userId") @db.Uuid
  /// 'pending' | 'approved' | 'denied' | 'expired'
  status       String   @default("pending")
  expiresAt    DateTime @map("expiresAt")
  /// Last poll timestamp — used to enforce the spec's `slow_down`
  /// response when a client polls below `interval`.
  lastPolledAt DateTime? @map("lastPolledAt")
  interval     Int      @default(5)
  createdAt    DateTime @default(now()) @map("createdAt")

  @@index([userCode])
  @@index([expiresAt])
  @@map("device_authorizations")
}

model UserKnownDevice {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("userId") @db.Uuid
  fingerprint String
  firstSeenAt DateTime @default(now()) @map("firstSeenAt")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@map("user_known_devices")
}
