<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{translations.title}}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            line-height: 1.6;
            color: #e2e8f0;
            background-color: #1a202c;
        }
        
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .email-header {
            background: {{headerGradient}};
            color: white;
            padding: 30px;
            text-align: center;
            border-radius: 8px 8px 0 0;
            position: relative;
        }
        
        .email-header h1 {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 8px;
        }
        
        .email-header .icon {
            position: absolute;
            top: 15px;
            right: 15px;
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }
        
        .email-body {
            background: #2d3748;
            padding: 40px 30px;
            border-radius: 0;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        }
        
        .greeting {
            font-size: 18px;
            color: #e2e8f0;
            margin-bottom: 20px;
        }
        
        .content {
            font-size: 16px;
            line-height: 1.6;
            color: #cbd5e0;
            margin-bottom: 30px;
        }
        
        .cta-button {
            display: inline-block;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px 30px;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 600;
            margin: 20px 0;
            transition: transform 0.2s;
        }
        
        .cta-button:hover {
            transform: translateY(-2px);
        }
        
        .message {
            margin-bottom: 25px;
        }
        
        .message p {
            margin-bottom: 15px;
            line-height: 1.6;
        }
        
        .cta {
            text-align: center;
            margin: 30px 0;
        }
        
        .expiry-text {
            font-size: 14px;
            color: #a0aec0;
            margin: 15px 0 10px 0;
        }
        
        .security-note {
            font-size: 14px;
            color: #a0aec0;
            margin: 10px 0;
            font-style: italic;
        }
        
        .features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }
        
        .feature {
            text-align: center;
            padding: 20px;
            background: #4a5568;
            border-radius: 8px;
        }
        
        .feature-icon {
            font-size: 32px;
            margin-bottom: 10px;
        }
        
        .feature h3 {
            font-size: 16px;
            color: #e2e8f0;
            margin-bottom: 8px;
        }
        
        .feature p {
            font-size: 14px;
            color: #cbd5e0;
        }
        
        .email-footer {
            text-align: center;
            padding: 30px;
            color: #a0aec0;
            font-size: 14px;
            background: #2d3748;
        }
        
        .email-footer a {
            color: #667eea;
            text-decoration: none;
        }
        
        .divider {
            height: 1px;
            background: #4a5568;
            margin: 30px 0;
        }
        
        @media (max-width: 600px) {
            .email-container {
                padding: 10px;
            }
            
            .email-header,
            .email-body {
                padding: 20px;
            }
            
            .email-header h1 {
                font-size: 20px;
            }
            
            .features {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="email-container">
        {{> header}}
        
        <div class="email-body">
            {{> @partial-block}}
        </div>
        
        {{> footer}}
    </div>
</body>
</html>
