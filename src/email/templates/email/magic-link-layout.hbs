{{#> layout
    headerGradient="linear-gradient(135deg, #667eea 0%, #764ba2 100%)"
    headerIcon="🔗"
    translations=translations
    app=app
}}
<div class="content" style="font-size: 16px; line-height: 1.6; color: #cbd5e0;">
    <div class="message" style="margin-bottom: 25px;">
        <p style="margin-bottom: 15px; line-height: 1.6;">{{{translations.message}}}</p>
    </div>
    
    <div class="cta" style="text-align: center; margin: 30px 0;">
        <a href="{{magicLink}}" class="cta-button" style="display: inline-block; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 15px 30px; text-decoration: none; border-radius: 6px; font-weight: 600; margin: 20px 0; transition: transform 0.2s;">{{translations.button}}</a>
        <p class="expiry-text" style="font-size: 14px; color: #a0aec0; margin: 15px 0 10px 0;">{{translations.expiry}}</p>
        <p class="security-note" style="font-size: 14px; color: #a0aec0; margin: 10px 0; font-style: italic;">{{translations.security}}</p>
    </div>
</div>
{{/layout}}
