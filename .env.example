# =============================================================================
# INITE Auth Service — example environment
# Copy to .env and fill in real values:  cp .env.example .env
# NEVER commit .env (already in .gitignore). See ENV-SETUP.md for prod secrets.
# =============================================================================

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
PORT=4000
SERVICE_VERSION=dev

# --- Database (PostgreSQL) ---------------------------------------------------
# Prisma reads DATABASE_URL. The discrete DB_* vars are used by some scripts.
DATABASE_URL=postgresql://auth:local_dev_password@localhost:5432/auth?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USER=auth
DB_PASSWORD=local_dev_password
DB_NAME=auth

# --- Redis -------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=local_dev_redis_password

# --- JWT / token signing -----------------------------------------------------
# Choose ONE mode.
#
# Mode A (recommended, inter-service): RS256 + JWKS. Generate:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Paste full PEM (with BEGIN/END lines), newlines as \n:
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
#
# Mode B (dev / single service): HS256. Generate: openssl rand -base64 64
JWT_SECRET=local_dev_jwt_secret_at_least_32_chars_long
JWT_ISSUER=https://auth.inite.ai
OIDC_ISSUER=https://auth.inite.ai

# Refresh-token lookup HMAC (HMAC-SHA256). MUST be independent of JWT_SECRET in
# prod — a leak of one must not burn the other. Generate: openssl rand -base64 64
# Falls back to JWT_SECRET if unset (dev convenience only; flagged in prod logs).
REFRESH_TOKEN_HMAC_SECRET=local_dev_refresh_token_hmac_at_least_32_chars

# Express session signing secret. Generate: openssl rand -base64 32
SESSION_SECRET=local_dev_session_secret_at_least_32_chars

# --- Decentralized identity (DID / Verifiable Credentials) -------------------
DID_METHOD=key
# Ed25519 private key the issuer signs Verifiable Credentials with.
# Generate a fresh one per environment — do not reuse across deployments.
# ISSUER_PRIVATE_KEY=<base64-encoded ed25519 private key>
# Custom JSON-LD @context appended to issued Verifiable Credentials.
# Point this at a context document you host.
VC_CONTEXT_URL=https://example.com/credentials/v1

# --- WebAuthn / Passkeys -----------------------------------------------------
# RP_ID must match the registrable domain (no scheme/port). For localhost dev
# use "localhost". RP_ORIGIN includes scheme + port.
RP_ID=localhost
RP_NAME=INITE
RP_ORIGIN=http://localhost:3000
WEBAUTHN_ATTESTATION_TYPE=none

# --- Have I Been Pwned (breached-password check) -----------------------------
HIBP_ENABLED=true
HIBP_MIN_BREACH_COUNT=1
HIBP_TIMEOUT_MS=2000

# --- CORS / frontend ---------------------------------------------------------
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
SUPPORT_EMAIL=support@inite.ai

# --- Email (SMTP / Mailgun) — optional for local dev -------------------------
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=2525
SMTP_USER=your_mailgun_user
SMTP_PASS=your_mailgun_pass
SMTP_FROM=noreply@inite.ai

# --- Observability (OpenTelemetry) — optional --------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=inite-auth-service
