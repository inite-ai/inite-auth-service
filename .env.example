# =============================================================================
# INITE Auth Service — example environment
# Copy to .env and fill in real values:  cp .env.example .env
# NEVER commit .env (already in .gitignore). See ENV-SETUP.md for prod secrets.
# =============================================================================

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
PORT=4000
SERVICE_VERSION=dev

# --- Database (PostgreSQL) ---------------------------------------------------
# Prisma reads DATABASE_URL. The discrete DB_* vars are used by some scripts.
DATABASE_URL=postgresql://auth:local_dev_password@localhost:5432/auth?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USER=auth
DB_PASSWORD=local_dev_password
DB_NAME=auth
# Consumed by docker-compose.yml to provision the bundled Postgres container and
# build its DATABASE_URL. Lets `cp .env.example .env && docker compose up` boot
# with zero edits. For host-run dev (no compose) DATABASE_URL above is used.
POSTGRES_PASSWORD=local_dev_password

# --- Redis -------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=local_dev_redis_password

# --- JWT / token signing -----------------------------------------------------
# Choose ONE mode.
#
# Mode A (recommended, inter-service): RS256 + JWKS. Generate:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Paste full PEM (with BEGIN/END lines), newlines as \n:
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
#
# Mode B (dev / single service): HS256. Generate: openssl rand -base64 64
JWT_SECRET=local_dev_jwt_secret_at_least_32_chars_long
JWT_ISSUER=https://auth.inite.ai
OIDC_ISSUER=https://auth.inite.ai

# Refresh-token lookup HMAC (HMAC-SHA256). MUST be independent of JWT_SECRET in
# prod — a leak of one must not burn the other. Generate: openssl rand -base64 64
# Falls back to JWT_SECRET if unset (dev convenience only; flagged in prod logs).
REFRESH_TOKEN_HMAC_SECRET=local_dev_refresh_token_hmac_at_least_32_chars

# Express session signing secret. Generate: openssl rand -base64 32
SESSION_SECRET=local_dev_session_secret_at_least_32_chars

# At-rest encryption key for sensitive fields (currently 2FA/TOTP secrets),
# AES-256-GCM. A 32-byte key as base64 or hex is used verbatim; any other
# value is SHA-256'd to 32 bytes. Generate: openssl rand -base64 32
# Required once any user enables TOTP 2FA. Rotating it strands existing 2FA
# secrets — re-enroll affected users. Keep independent of JWT_SECRET.
FIELD_ENCRYPTION_KEY=local_dev_field_encryption_key_at_least_32b

# --- Decentralized identity (DID / Verifiable Credentials) -------------------
DID_METHOD=key
# Ed25519 private key the issuer signs Verifiable Credentials with.
# Generate a fresh one per environment — do not reuse across deployments.
# ISSUER_PRIVATE_KEY=<base64-encoded ed25519 private key>
# Custom JSON-LD @context appended to issued Verifiable Credentials.
# Point this at a context document you host.
VC_CONTEXT_URL=https://example.com/credentials/v1

# --- WebAuthn / Passkeys -----------------------------------------------------
# RP_ID must match the registrable domain (no scheme/port). For localhost dev
# use "localhost". RP_ORIGIN includes scheme + port.
RP_ID=localhost
RP_NAME=INITE
RP_ORIGIN=http://localhost:3000
WEBAUTHN_ATTESTATION_TYPE=none

# --- Have I Been Pwned (breached-password check) -----------------------------
HIBP_ENABLED=true
HIBP_MIN_BREACH_COUNT=1
HIBP_TIMEOUT_MS=2000

# --- Social login / external IdP federation (all optional) -------------------
# Each provider activates only when its client id + secret are both set.
# Redirect/callback URL to register at the provider:
#   <FEDERATION_REDIRECT_BASE or OIDC_ISSUER>/v1/auth/oauth/<provider>/callback
# e.g. https://auth.inite.ai/v1/auth/oauth/google/callback
# FEDERATION_REDIRECT_BASE=https://auth.inite.ai
#
# Google (OIDC). Console: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
#
# GitHub (OAuth). Settings → Developer settings → OAuth Apps
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
#
# Generic OIDC connector (Okta, Auth0, Keycloak, Entra ID, …). Endpoints are
# resolved from <issuer>/.well-known/openid-configuration.
# OIDC_FEDERATION_ISSUER=https://your-idp.example.com
# OIDC_FEDERATION_CLIENT_ID=
# OIDC_FEDERATION_CLIENT_SECRET=
# OIDC_FEDERATION_NAME=Single Sign-On
# OIDC_FEDERATION_SCOPES=openid email profile

# --- CORS / frontend ---------------------------------------------------------
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
SUPPORT_EMAIL=support@inite.ai

# --- Email (SMTP / Mailgun) — optional for local dev -------------------------
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=2525
SMTP_USER=your_mailgun_user
SMTP_PASS=your_mailgun_pass
SMTP_FROM=noreply@inite.ai

# --- SMS OTP (Twilio) — optional ---------------------------------------------
# Email OTP works out of the box on the SMTP config above. The SMS channel
# activates only when all three Twilio vars are set; otherwise the OTP service
# refuses the sms channel with a clear error. Provider is pluggable
# (src/auth/otp/sms) — swap TwilioSmsProvider in otp.module.ts for another.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+10000000000

# --- Audit log export webhook — optional -------------------------------------
# When set, every persisted audit event is also POSTed (best-effort, time-boxed)
# to this URL so a SIEM / log pipeline can ingest it. If a secret is set the
# body is signed: header `X-INITE-Signature: sha256=<hmac>`.
# AUDIT_WEBHOOK_URL=https://siem.example.com/ingest/inite-audit
# AUDIT_WEBHOOK_SECRET=

# --- Observability (OpenTelemetry) — optional --------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=inite-auth-service
