generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String    @id @default(uuid()) @db.Uuid
  did                      String    @unique
  email                    String?   @unique
  emailVerified            Boolean   @default(false) @map("emailVerified")
  name                     String?
  avatarUrl                String?   @map("avatarUrl")
  bio                      String?
  location                 String?
  profession               String?
  passwordHash             String?   @map("passwordHash")
  twoFactorSecret          String?   @map("twoFactorSecret")
  twoFactorEnabled         Boolean   @default(false) @map("twoFactorEnabled")
  emailVerificationToken   String?   @map("emailVerificationToken")
  emailVerificationExpires DateTime? @map("emailVerificationExpires")
  passwordResetToken       String?   @map("passwordResetToken")
  passwordResetExpires     DateTime? @map("passwordResetExpires")
  /// Number of consecutive failed password-login attempts. Reset to 0
  /// on successful login. Drives exponential backoff in
  /// AuthService.loginWithPassword — see lockoutUntil.
  failedLoginCount         Int       @default(0) @map("failedLoginCount")
  /// Timestamp until which password-login is rejected for this user.
  /// Cleared on successful login. Set after failedLoginCount crosses
  /// 5 with progressively longer windows (1m → 5m → 15m → 1h → 24h).
  lockoutUntil             DateTime? @map("lockoutUntil")
  metadata                 Json?
  createdAt                DateTime  @default(now()) @map("createdAt")
  updatedAt                DateTime  @updatedAt @map("updatedAt")

  passkeys           Passkey[]
  wallets            Wallet[]
  refreshTokens      RefreshToken[]
  authorizationCodes AuthorizationCode[]
  magicLinks         MagicLink[]
  knownDevices       UserKnownDevice[]

  @@map("users")
}

model Passkey {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("userId") @db.Uuid
  credentialId String   @unique @map("credentialId")
  publicKey    String   @map("publicKey") @db.Text
  counter      Int      @default(0)
  deviceType   String?  @map("deviceType")
  deviceName   String?  @map("deviceName")
  transports   Json?
  createdAt    DateTime @default(now()) @map("createdAt")
  lastUsedAt   DateTime @updatedAt @map("lastUsedAt")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}

model Wallet {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("userId") @db.Uuid
  address   String   @unique
  chain     String
  signature String   @db.Text
  message   String?  @db.Text
  linkedAt  DateTime @default(now()) @map("linkedAt")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("wallets")
}

model OAuthClient {
  id                String   @id @default(uuid()) @db.Uuid
  clientId          String   @unique @map("clientId")
  clientSecretHash  String   @map("clientSecretHash")
  /// Previous client_secret hash retained during the grace window
  /// after rotation. validateClient accepts both current and previous
  /// hashes until `previousSecretExpiresAt`, giving deployed callers
  /// time to roll forward without an outage.
  previousSecretHash       String?   @map("previousSecretHash")
  previousSecretExpiresAt  DateTime? @map("previousSecretExpiresAt")
  name              String
  redirectUris      String[] @map("redirectUris")
  allowedScopes     String[] @default([]) @map("allowedScopes")
  allowedGrants     String[] @default(["authorization_code", "refresh_token"]) @map("allowedGrants")
  /// Tenant identifier embedded as `sub` in JWTs issued via the
  /// client_credentials grant. Null for user-flow clients (those use
  /// the user's DID as sub). Set for machine clients calling brain
  /// or other horizontal services that key data by company.
  companyId         String?  @map("companyId")
  /// Permitted audiences for M2M JWTs. Without this allow-list a
  /// stolen client_credentials pair could mint tokens for any
  /// downstream service. Empty array = "no constraint" (issuer falls
  /// back to clientId as audience). Set explicitly when provisioning
  /// machine clients via the admin UI.
  allowedAudiences  String[] @default([]) @map("allowedAudiences")
  active            Boolean  @default(true)
  logoUrl           String?  @map("logoUrl")
  privacyPolicyUrl  String?  @map("privacyPolicyUrl")
  termsOfServiceUrl String?  @map("termsOfServiceUrl")
  createdAt         DateTime @default(now()) @map("createdAt")
  updatedAt         DateTime @updatedAt @map("updatedAt")

  refreshTokens      RefreshToken[]
  authorizationCodes AuthorizationCode[]

  @@map("oauth_clients")
}

/// Durable audit trail for OAuth + client lifecycle events.
/// Replaces console-only logging so security forensics and
/// compliance reviews don't depend on container log retention.
model OAuthAuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  ts            DateTime @default(now())
  event         String
  clientId      String?
  sub           String?
  scopes        String[] @default([])
  audience      String?
  ip            String?
  userAgent     String?
  success       Boolean
  errorMessage  String?
  metadata      Json?

  @@index([clientId, ts(sort: Desc)], map: "oauth_audit_log_clientId_ts_idx")
  @@index([event, ts(sort: Desc)], map: "oauth_audit_log_event_ts_idx")
  @@map("oauth_audit_log")
}

model AuthorizationCode {
  id                  String   @id @default(uuid()) @db.Uuid
  code                String   @unique
  userId              String   @map("userId") @db.Uuid
  clientId            String   @map("clientId")
  redirectUri         String   @map("redirectUri")
  scope               String?
  /// OIDC nonce parameter (core §3.1.2.1). Persisted at /authorize and
  /// embedded into the id_token at /token. Required to bind a given
  /// id_token to the original authorization request — without it, an
  /// attacker who intercepts a code can replay a stolen id_token.
  nonce               String?
  codeChallenge       String?  @map("codeChallenge")
  codeChallengeMethod String?  @map("codeChallengeMethod")
  expiresAt           DateTime @map("expiresAt")
  used                Boolean  @default(false)
  createdAt           DateTime @default(now()) @map("createdAt")

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([userId])
  @@map("authorization_codes")
}

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  // Deterministic HMAC-SHA256(REFRESH_TOKEN_HMAC_SECRET, rawToken) used for
  // O(1) indexed lookup AND verification (knowing the lookup proves the
  // token was minted with this server's HMAC secret). Replaces the previous
  // bcrypt-based scan-all-rows-and-compare approach.
  tokenLookup String?   @unique @map("tokenLookup")
  // Legacy bcrypt-hashed value, only present on rows minted before the
  // refresh-token rewrite. New rows leave this null. Cleanup cron will
  // delete legacy rows once they expire (max 7d).
  tokenHash   String?   @map("tokenHash")
  userId      String    @map("userId") @db.Uuid
  clientId    String    @map("clientId")
  scope       String?
  /// OIDC nonce carried forward across refresh-token rotation, so
  /// id_tokens minted via refresh still embed the same nonce as the
  /// original (OIDC core §12.1).
  nonce       String?
  expiresAt   DateTime  @map("expiresAt")
  rotatedFrom String?   @map("rotatedFrom") @db.Uuid
  revoked     Boolean   @default(false)
  revokedAt   DateTime? @map("revokedAt")
  createdAt   DateTime  @default(now()) @map("createdAt")

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([userId])
  @@index([userId, clientId, revoked])
  @@map("refresh_tokens")
}

model MagicLink {
  id          String    @id @default(uuid()) @db.Uuid
  token       String    @unique
  email       String
  userId      String?   @map("userId") @db.Uuid
  purpose     String
  expiresAt   DateTime  @map("expiresAt")
  used        Boolean   @default(false)
  usedAt      DateTime? @map("usedAt")
  oauthParams Json?     @map("oauthParams")
  createdAt   DateTime  @default(now()) @map("createdAt")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("magic_links")
}

model UserKnownDevice {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("userId") @db.Uuid
  fingerprint String
  firstSeenAt DateTime @default(now()) @map("firstSeenAt")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@map("user_known_devices")
}
