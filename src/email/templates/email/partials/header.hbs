<tr>
    <td style="background:{{headerGradient}};color:#ffffff;padding:28px 24px;text-align:center;border-radius:12px 12px 0 0;">
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
            <tr>
                <td align="center">
                    {{#if headerIcon}}
                    <span style="display:inline-block;width:44px;height:44px;line-height:44px;background:rgba(255,255,255,0.2);border-radius:50%;font-size:22px;text-align:center;margin-bottom:12px;">{{headerIcon}}</span>
                    {{/if}}
                    <h1 style="margin:0;font-size:22px;font-weight:600;color:#ffffff;">{{translations.title}}</h1>
                </td>
            </tr>
        </table>
    </td>
</tr>
