{
  "name": "inite-auth-service",
  "version": "1.8.0",
  "description": "INITE Identity Provider - Unified authentication service for all INITE ecosystem modules",
  "author": "INITE",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "build": "nest build",
    "postinstall": "prisma generate",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:migrate:deploy": "npx prisma migrate deploy",
    "prisma:studio": "npx prisma studio",
    "register-client": "ts-node -r tsconfig-paths/register scripts/register-client.example.ts",
    "register-auth-admin-tools-client": "ts-node -r tsconfig-paths/register scripts/register-auth-admin-tools-client.ts",
    "register-all-clients": "npm run register-auth-admin-tools-client",
    "create-admin": "ts-node -r tsconfig-paths/register scripts/create-admin-user.ts",
    "encrypt-totp-secrets": "ts-node -r tsconfig-paths/register scripts/encrypt-totp-secrets.ts",
    "backfill-memberships": "ts-node -r tsconfig-paths/register scripts/backfill-memberships.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@node-saml/node-saml": "^5.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@simplewebauthn/server": "^13.3.2",
    "@simplewebauthn/types": "^12.0.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cookie-signature": "^1.2.2",
    "did-jwt": "^8.0.18",
    "did-resolver": "^5.0.1",
    "dotenv": "^17.4.2",
    "ethers": "^6.17.0",
    "express-session": "^1.19.0",
    "handlebars": "^4.7.9",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "speakeasy": "^2.0.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cookie-signature": "^1.1.2",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.1",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "comments": {
    "overrides": "Pin patched versions of transitive deps flagged by Dependabot (mostly build/test tooling). Patch-level bumps only — no API-breaking majors. picomatch is scoped under micromatch to keep the 2.x line patched without disturbing 4.x consumers."
  },
  "overrides": {
    "multer": "^2.2.0",
    "form-data": "^4.0.6",
    "fast-uri": "^3.1.2",
    "flatted": "^3.4.2",
    "@babel/core": "^7.29.6",
    "micromatch": {
      "picomatch": "^2.3.2"
    },
    "anymatch": {
      "picomatch": "^2.3.2"
    }
  }
}
